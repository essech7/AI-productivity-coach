<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coach.app.controllers.DashboardController">
   <children>
      <TabPane layoutX="-1.0" prefHeight="650.0" prefWidth="850.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <tabs>
          <Tab text="Gestion des Tâches">
               <content>
                  <SplitPane dividerPositions="0.4" prefHeight="160.0" prefWidth="200.0">
                    <items>
                      <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                           <children>
                              <VBox layoutX="-3.0" layoutY="-1.0" prefHeight="572.0" prefWidth="320.0" spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <children>
                                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Nouvelle Tâche" />
                                    <TextField fx:id="taskTitleField" promptText="Titre de la tâche" />
                                    <TextArea fx:id="taskDescField" prefHeight="80.0" promptText="Description..." />
                                    <HBox spacing="10.0">
                                       <children>
                                          <ComboBox fx:id="categoryCombo" prefWidth="150.0" />
                                          <DatePicker fx:id="deadlinePicker" prefWidth="150.0" />
                                       </children>
                                    </HBox>
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddTask" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Ajouter la tâche" />
                                    <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCompleteTask" style="-fx-background-color: #9C27B0; -fx-text-fill: white;" text="Marquer la tâche séléctionnée comme Terminée" />
                                 </children>
                                 <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                 </padding>
                              </VBox>
                           </children>
                        </AnchorPane>
                      <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                           <children>
                              <VBox prefHeight="571.0" prefWidth="475.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <children>
                                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Mes Tâches">
                                       <padding>
                                          <Insets bottom="10.0" left="10.0" top="10.0" />
                                       </padding>
                                    </Label>
                                    <ListView fx:id="taskListView" prefHeight="532.0" prefWidth="475.0" VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>
                           </children>
                        </AnchorPane>
                    </items>
                  </SplitPane>
               </content>
          </Tab>
          
          <Tab text="Assistant IA (Gemini)">
               <content>
                  <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                     <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Mon Coach Intelligent" />
                        <Label text="L'IA peut vous aider à découper vos grandes tâches ou à reformuler vos objectifs flous." />
                        <TextArea fx:id="aiPromptArea" prefHeight="80.0" promptText="Saisissez un objectif flou ou une tâche complexe ici (Ex: Je dois réviser mon examen Java)" />
                        <HBox spacing="10.0">
                            <Button mnemonicParsing="false" onAction="#handleAskAi" style="-fx-background-color: #ff9800; -fx-text-fill: white;" text="Demander Avis Libre" />
                            <Button mnemonicParsing="false" onAction="#handleBreakdown" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Structurer la Tâche" />
                            <Button mnemonicParsing="false" onAction="#handleReformulate" style="-fx-background-color: #00BCD4; -fx-text-fill: white;" text="Reformuler (Objectif SMART)" />
                        </HBox>
                        <TextArea fx:id="aiResponseArea" editable="false" prefHeight="350.0" promptText="La réponse de l'IA détaillée apparaîtra ici..." wrapText="true" VBox.vgrow="ALWAYS" />
                     </children>
                     <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                     </padding>
                  </VBox>
               </content>
          </Tab>
          
          <Tab text="Statistiques &amp; Suivi">
              <content>
                  <VBox alignment="CENTER" spacing="20.0">
                      <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Historique &amp; Productivité" />
                      <Label fx:id="completionRateLabel" style="-fx-font-size: 16px;" text="Taux de complétion : Calcule en cours..." />
                      <Button mnemonicParsing="false" onAction="#handleRefreshStats" text="Rafraichir les Statistiques" />
                  </VBox>
              </content>
          </Tab>
          
        </tabs>
      </TabPane>
   </children>
</AnchorPane>
