<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coach.app.controllers.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Bienvenue sur AI Productivity Coach" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="usernameField" promptText="Nom d'utilisateur" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Mot de passe" maxWidth="250"/>
    
    <HBox alignment="CENTER" spacing="10">
        <Button text="Se Connecter" onAction="#handleLogin" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="S'inscrire" onAction="#handleRegister" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>
    
    <Label fx:id="errorLabel" textFill="RED"/>
</VBox>
