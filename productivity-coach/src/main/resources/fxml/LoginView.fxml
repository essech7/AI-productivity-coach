<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.productivitycoach.ui.controllers.LoginController"
           styleClass="root-pane">

    <VBox alignment="CENTER" spacing="0" maxWidth="420"
          styleClass="card-login">

        <!-- En-tête -->
        <VBox alignment="CENTER" spacing="8" styleClass="card-header">
            <Label text="⚡" styleClass="logo-icon"/>
            <Label text="AI Productivity Coach" styleClass="app-title"/>
            <Label text="Connectez-vous pour continuer" styleClass="subtitle"/>
        </VBox>

        <!-- Formulaire -->
        <VBox spacing="16" styleClass="form-body">
            <VBox spacing="6">
                <Label text="Adresse email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="vous@exemple.com"
                           styleClass="text-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Mot de passe" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               styleClass="text-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label"
                   visible="false" wrapText="true"/>

            <Button text="Se connecter"
                    onAction="#handleLogin"
                    fx:id="loginButton"
                    maxWidth="Infinity"
                    styleClass="btn-primary"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas encore de compte ?" styleClass="muted-text"/>
                <Hyperlink text="S'inscrire"
                           fx:id="registerLink"
                           onAction="#handleRegisterLink"
                           styleClass="link"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
